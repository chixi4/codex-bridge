#!/usr/bin/env bash
set -euo pipefail

CONFIG="${CODEX_BRIDGE_ENV:-$HOME/.config/codex-bridge/env}"
if [[ -f "$CONFIG" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$CONFIG"
  set +a
fi

DISTRO="${WSL_DISTRO:-Ubuntu-20.04}"
AUTH_DISTROS="${CODEX_AUTH_DISTROS:-${DISTRO},IsaacLab-22.04}"

logout_one() {
  local distro="$1"
  echo "== ${distro} =="
  "$(dirname "$0")/win-ssh" "wsl -d ${distro} -- bash -lc \"if ! command -v codex >/dev/null 2>&1; then echo codex-not-installed-in-this-WSL; exit 0; fi; codex logout || true\""
}

seen=","
IFS=',' read -r -a targets <<< "$AUTH_DISTROS"
for distro in "${targets[@]}"; do
  distro="${distro#"${distro%%[![:space:]]*}"}"
  distro="${distro%"${distro##*[![:space:]]}"}"
  [[ -n "$distro" ]] || continue
  [[ "$seen" == *",$distro,"* ]] && continue
  seen="${seen}${distro},"
  logout_one "$distro"
done
