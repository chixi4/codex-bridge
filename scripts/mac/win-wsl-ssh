#!/usr/bin/env bash
set -euo pipefail

CONFIG="${CODEX_BRIDGE_ENV:-$HOME/.config/codex-bridge/env}"
if [[ -f "$CONFIG" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$CONFIG"
  set +a
fi

DISTRO="${WSL_DISTRO:-Ubuntu-20.04}"
SSH_KEY="${SSH_KEY:-$HOME/.ssh/nvidia_garlic_node05_vllm}"
WSL_SSHD_PORT="${WSL_SSHD_PORT:-2222}"
KNOWN_HOSTS="${CODEX_BRIDGE_WSL_KNOWN_HOSTS:-$HOME/.ssh/codex_bridge_wsl_known_hosts}"
WIN_SSH="$(dirname "$0")/win-ssh"

if [[ ! -r "$SSH_KEY" ]]; then
  echo "SSH key not readable: $SSH_KEY" >&2
  exit 2
fi

if [[ ! -r "${SSH_KEY}.pub" ]]; then
  echo "SSH public key not found: ${SSH_KEY}.pub" >&2
  exit 2
fi

start_wsl_sshd() {
  local pubkey script
  pubkey="$(sed -n '1p' "${SSH_KEY}.pub")"
  script="$(cat <<'EOS'
set -euo pipefail
pubkey='__PUBKEY__'
port='__PORT__'

mkdir -p /root/.ssh
chmod 700 /root/.ssh
touch /root/.ssh/authorized_keys
chmod 600 /root/.ssh/authorized_keys
if ! grep -qxF "$pubkey" /root/.ssh/authorized_keys; then
  printf '%s\n' "$pubkey" >> /root/.ssh/authorized_keys
fi

ssh-keygen -A
mkdir -p /run/sshd

if ss -ltnp 2>/dev/null | grep -q ":${port}"; then
  exit 0
fi

nohup /usr/sbin/sshd -D -p "$port" \
  -o ListenAddress=127.0.0.1 \
  -o PasswordAuthentication=no \
  -o PubkeyAuthentication=yes \
  -o PermitRootLogin=prohibit-password \
  -o AuthorizedKeysFile=.ssh/authorized_keys \
  >/tmp/codex-bridge-wsl-sshd.log 2>&1 &

sleep 0.4
ss -ltnp 2>/dev/null | grep -q ":${port}" || {
  echo "WSL sshd failed to start on port ${port}" >&2
  cat /tmp/codex-bridge-wsl-sshd.log >&2 2>/dev/null || true
  exit 1
}
EOS
)"
  script="${script/__PUBKEY__/$pubkey}"
  script="${script/__PORT__/$WSL_SSHD_PORT}"
  printf '%s\n' "$script" | base64 | "$WIN_SSH" \
    "wsl -d ${DISTRO} -- bash -lc \"base64 -d | bash\""
}

start_wsl_sshd

ssh_args=(
  -i "$SSH_KEY"
  -o IdentitiesOnly=yes
  -o StrictHostKeyChecking=accept-new
  -o UserKnownHostsFile="$KNOWN_HOSTS"
  -o "ProxyCommand=${WIN_SSH} wsl -d ${DISTRO} -- nc 127.0.0.1 ${WSL_SSHD_PORT}"
)

if [[ -t 0 && -t 1 ]]; then
  ssh_args+=(-t)
fi

exec ssh "${ssh_args[@]}" root@codex-bridge-wsl "$@"
