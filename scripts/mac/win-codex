#!/usr/bin/env bash
set -euo pipefail

CONFIG="${CODEX_BRIDGE_ENV:-$HOME/.config/codex-bridge/env}"
if [[ -f "$CONFIG" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$CONFIG"
  set +a
fi

DISTRO="${WSL_DISTRO:-Ubuntu-20.04}"
AUTH_DISTROS="${CODEX_AUTH_DISTROS:-${DISTRO},IsaacLab-22.04}"

for_auth_distro() {
  local raw distro seen=","
  IFS=',' read -r -a raw <<< "$AUTH_DISTROS"
  for distro in "${raw[@]}"; do
    distro="${distro#"${distro%%[![:space:]]*}"}"
    distro="${distro%"${distro##*[![:space:]]}"}"
    [[ -n "$distro" ]] || continue
    [[ "$seen" == *",$distro,"* ]] && continue
    seen="${seen}${distro},"
    "$@" "$distro"
  done
}

status_one() {
  local distro="$1"
  echo "== ${distro} =="
  "$(dirname "$0")/win-ssh" "wsl -d ${distro} -- bash -lc \"if ! command -v codex >/dev/null 2>&1; then echo codex-not-installed-in-this-WSL; exit 0; fi; codex login status || true\""
}

cmd="${1:-}"
case "$cmd" in
  login)
    shift
    exec "$(dirname "$0")/win-codex-login" "$@"
    ;;
  logout)
    shift
    exec "$(dirname "$0")/win-codex-logout" "$@"
    ;;
  migrate-sessions|import-sessions)
    shift
    exec "$(dirname "$0")/win-codex-migrate-sessions" "$@"
    ;;
  status)
    shift || true
    for_auth_distro status_one
    ;;
  *)
    cat <<'EOF'
Usage:
  win-codex login    Log in remote WSL Codex through this Mac browser
  win-codex logout   Log out remote WSL Codex
  win-codex status   Show remote WSL Codex login status
  win-codex migrate-sessions [from] [to]
EOF
    ;;
esac
