# Copy to ~/.config/codex-bridge/env and edit if your machine changes.

REMOTE_USER=administrator
REMOTE_HOST=10.251.1.15
SSH_KEY=$HOME/.ssh/nvidia_garlic_node05_vllm

# EZ4Connect / campus SOCKS endpoint on the Mac.
CAMPUS_SOCKS_HOST=127.0.0.1
CAMPUS_SOCKS_PORT=11080

# Mac internet proxy that can reach OpenAI/Google/npm.
MAC_PROXY_HOST=127.0.0.1
MAC_PROXY_PORT=7897

# SSH reverse tunnel: Windows 127.0.0.1:17897 -> Mac 127.0.0.1:7897.
REMOTE_FORWARD_PORT=17897

# Windows portproxy: WSL gateway:17898 -> Windows localhost:17897.
WSL_HOST_PROXY_PORT=17898

# Pick the WSL distro that actually contains the project runtime.
# For the current T1/IsaacGym route this is Ubuntu-20.04, not the empty
# placeholder named IsaacLab-22.04.
WSL_DISTRO=Ubuntu-20.04
OAUTH_CALLBACK_PORT=1455
